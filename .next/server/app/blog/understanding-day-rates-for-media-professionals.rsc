0:["psdu3ijGrdNaEXr5inVpP",[[["",{"children":["blog",{"children":[["slug","understanding-day-rates-for-media-professionals","d"],{"children":["__PAGE__?{\"slug\":\"understanding-day-rates-for-media-professionals\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["blog",{"children":[["slug","understanding-day-rates-for-media-professionals","d"],{"children":["__PAGE__",{},[["$L1",[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"Understanding Day Rates: How Media Professionals Price Their Work\",\"description\":\"Day rates can seem mysterious if you've never hired a freelance media professional before. Here's how they work and what's typically included.\",\"datePublished\":\"2026-03-07\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Gulf Coast Production Network\",\"url\":\"https://gulfcoastproductionnetwork.com\"},\"mainEntityOfPage\":\"https://gulfcoastproductionnetwork.com/blog/understanding-day-rates-for-media-professionals\"}"}}],["$","div",null,{"className":"pt-16 min-h-screen","children":[["$","div",null,{"className":"max-w-3xl mx-auto px-4 pt-12 pb-8","children":[["$","$L2",null,{"href":"/blog","className":"text-teal text-xs font-condensed tracking-widest uppercase hover:underline mb-6 inline-block","children":"← Back to Guides"}],["$","div",null,{"className":"flex items-center gap-3 mb-4","children":[["$","span",null,{"className":"font-condensed text-[10px] tracking-widest uppercase bg-teal/10 text-teal border border-teal/20 px-2 py-0.5 rounded","children":"Hiring Tips"}],["$","span",null,{"className":"text-muted text-xs","children":"5 min read"}],["$","span",null,{"className":"text-muted text-xs","children":"·"}],["$","span",null,{"className":"text-muted text-xs","children":"March 6, 2026"}]]}],["$","h1",null,{"className":"font-display text-4xl md:text-5xl tracking-widest text-white leading-tight mb-6","children":"Understanding Day Rates: How Media Professionals Price Their Work"}],["$","p",null,{"className":"text-muted text-lg leading-relaxed border-l-2 border-teal pl-4","children":"Day rates can seem mysterious if you've never hired a freelance media professional before. Here's how they work and what's typically included."}]]}],["$","div",null,{"className":"max-w-3xl mx-auto px-4","children":["$","div",null,{"className":"border-t border-white/[0.06] mb-10"}]}],["$","article",null,{"className":"max-w-3xl mx-auto px-4 pb-16","children":[[["$","p","0",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["When you start reaching out to videographers, photographers, audio engineers, or other media professionals, you'll quickly run into the term \"day rate.\" If you're used to hourly billing or fixed project prices, day rates can feel a little confusing. Here's a plain-language explanation of how they work."]}],["$","h2","1",{"className":"font-display text-2xl tracking-widest text-white mt-10 mb-4","children":"What Is a Day Rate?"}],["$","p","2",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["A day rate is a flat fee for a full day of work — typically defined as eight to ten hours on set or on location. It's the standard way most freelance media professionals price their time, and it comes from the film and television industry where production days are long and unpredictable."]}],["$","p","3",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["Rather than tracking every hour, a day rate gives both sides a clear, agreed-upon number before the job starts."]}],["$","h2","4",{"className":"font-display text-2xl tracking-widest text-white mt-10 mb-4","children":"What's Usually Included"}],["$","p","5",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["A day rate covers the professional's time and skill. It does not always include:"]}],["$","ul","6",{"className":"list-disc pl-6 mb-4 space-y-2","children":[["$","li","0",{"className":"text-white/75 text-sm leading-relaxed","children":"**Equipment** — Cameras, lighting, audio gear, and other specialized equipment are often quoted separately as a kit fee"}],["$","li","1",{"className":"text-white/75 text-sm leading-relaxed","children":"**Editing and post-production** — Shooting and editing are typically billed separately"}],["$","li","2",{"className":"text-white/75 text-sm leading-relaxed","children":"**Travel** — Significant travel time or mileage beyond a local radius may be added"}],["$","li","3",{"className":"text-white/75 text-sm leading-relaxed","children":"**Additional crew** — If the job requires a second shooter, gaffer, or sound person, each has their own rate"}]]}],["$","p","7",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["Always ask for an itemized quote so you understand exactly what's in the number you're being given."]}],["$","h2","8",{"className":"font-display text-2xl tracking-widest text-white mt-10 mb-4","children":"Half Days"}],["$","p","9",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["Most professionals also offer a half-day rate for shorter shoots, typically defined as four to five hours. Half-day rates are usually not exactly half the day rate — they're often around 60 to 65 percent of the full day rate — because the professional is still blocking out a significant portion of their day for your project."]}],["$","h2","10",{"className":"font-display text-2xl tracking-widest text-white mt-10 mb-4","children":"Why Rates Vary"}],["$","p","11",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["Day rates across the Gulf Coast vary based on experience, specialization, and demand. A broadcast camera operator with network credits will have a higher rate than someone newer to the industry. A drone operator with FAA certification and specialized equipment will reflect that in their pricing. A seasoned audio engineer who has mixed live television will charge accordingly."]}],["$","p","12",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["Rates also vary by market. New Orleans rates tend to be higher than smaller Gulf Coast markets due to the volume of production work in the city."]}],["$","h2","13",{"className":"font-display text-2xl tracking-widest text-white mt-10 mb-4","children":"How to Use This Information"}],["$","p","14",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["When you're budgeting a project, start by getting rates from two or three professionals. Ask each one for a full breakdown of what's included. Don't just compare the day rate number — compare what you're getting for it. The lowest rate is rarely the best value."]}],["$","p","15",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["A clear conversation about budget and scope before the shoot day will prevent misunderstandings and set the project up for success."]}]],["$","div",null,{"className":"mt-12 bg-gradient-to-br from-teal/10 to-transparent border border-teal/20 rounded-2xl p-8 text-center","children":[["$","h3",null,{"className":"font-display text-2xl tracking-widest mb-3","children":"Find a Professional on the Gulf Coast"}],["$","p",null,{"className":"text-muted text-sm mb-6","children":"Browse verified media professionals available for your next project — from Tallahassee to New Orleans."}],["$","div",null,{"className":"flex gap-4 justify-center flex-wrap","children":[["$","$L2",null,{"href":"/browse","className":"btn-teal font-display tracking-widest px-6 py-2","children":"Browse Pros"}],["$","$L2",null,{"href":"/post-job","className":"btn-outline font-display tracking-widest px-6 py-2","children":"Post a Job"}]]}]]}]]}],["$","div",null,{"className":"bg-navy2 border-t border-white/[0.06] py-12 px-4","children":["$","div",null,{"className":"max-w-6xl mx-auto","children":[["$","h2",null,{"className":"font-display text-2xl tracking-widest mb-8 text-center","children":"More Guides"}],["