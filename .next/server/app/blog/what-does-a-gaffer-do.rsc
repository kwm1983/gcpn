0:["psdu3ijGrdNaEXr5inVpP",[[["",{"children":["blog",{"children":[["slug","what-does-a-gaffer-do","d"],{"children":["__PAGE__?{\"slug\":\"what-does-a-gaffer-do\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["blog",{"children":[["slug","what-does-a-gaffer-do","d"],{"children":["__PAGE__",{},[["$L1",[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"What Does a Gaffer Do? Lighting Explained for Non-Filmmakers\",\"description\":\"You've seen the word \\\"gaffer\\\" in movie credits but never knew what it meant. Here's what a gaffer does and why lighting matters more than most people realize.\",\"datePublished\":\"2026-03-09\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Gulf Coast Production Network\",\"url\":\"https://gulfcoastproductionnetwork.com\"},\"mainEntityOfPage\":\"https://gulfcoastproductionnetwork.com/blog/what-does-a-gaffer-do\"}"}}],["$","div",null,{"className":"pt-16 min-h-screen","children":[["$","div",null,{"className":"max-w-3xl mx-auto px-4 pt-12 pb-8","children":[["$","$L2",null,{"href":"/blog","className":"text-teal text-xs font-condensed tracking-widest uppercase hover:underline mb-6 inline-block","children":"← Back to Guides"}],["$","div",null,{"className":"flex items-center gap-3 mb-4","children":[["$","span",null,{"className":"font-condensed text-[10px] tracking-widest uppercase bg-teal/10 text-teal border border-teal/20 px-2 py-0.5 rounded","children":"Industry Basics"}],["$","span",null,{"className":"text-muted text-xs","children":"4 min read"}],["$","span",null,{"className":"text-muted text-xs","children":"·"}],["$","span",null,{"className":"text-muted text-xs","children":"March 8, 2026"}]]}],["$","h1",null,{"className":"font-display text-4xl md:text-5xl tracking-widest text-white leading-tight mb-6","children":"What Does a Gaffer Do? Lighting Explained for Non-Filmmakers"}],["$","p",null,{"className":"text-muted text-lg leading-relaxed border-l-2 border-teal pl-4","children":"You've seen the word \"gaffer\" in movie credits but never knew what it meant. Here's what a gaffer does and why lighting matters more than most people realize."}]]}],["$","div",null,{"className":"max-w-3xl mx-auto px-4","children":["$","div",null,{"className":"border-t border-white/[0.06] mb-10"}]}],["$","article",null,{"className":"max-w-3xl mx-auto px-4 pb-16","children":[[["$","p","0",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["If you've ever sat through movie credits and wondered what a gaffer actually does, you're not alone. It's one of those job titles that sounds made up but refers to one of the most important roles on any professional production."]}],["$","h2","1",{"className":"font-display text-2xl tracking-widest text-white mt-10 mb-4","children":"The Short Version"}],["$","p","2",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["A gaffer is the head of the lighting department on a film, television, or video production. They're responsible for designing and executing the lighting plan that makes the footage look the way the director of photography intends."]}],["$","h2","3",{"className":"font-display text-2xl tracking-widest text-white mt-10 mb-4","children":"What They Actually Do on Set"}],["$","p","4",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["The gaffer works closely with the director of photography (DP) to understand the visual goals of the project. Then they figure out how to achieve those goals with light — what fixtures to use, where to place them, how to power them, and how to shape and control the light to get the right look."]}],["$","p","5",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["On a large production, the gaffer oversees a team of electricians and lighting technicians. On smaller productions, a gaffer might work solo, handling both the planning and the physical setup."]}],["$","p","6",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["Their responsibilities typically include:"]}],["$","ul","7",{"className":"list-disc pl-6 mb-4 space-y-2","children":[["$","li","0",{"className":"text-white/75 text-sm leading-relaxed","children":"Reading the shot list and understanding what each scene needs visually"}],["$","li","1",{"className":"text-white/75 text-sm leading-relaxed","children":"Selecting and positioning lighting equipment"}],["$","li","2",{"className":"text-white/75 text-sm leading-relaxed","children":"Managing power distribution on set"}],["$","li","3",{"className":"text-white/75 text-sm leading-relaxed","children":"Rigging lights safely in challenging locations"}],["$","li","4",{"className":"text-white/75 text-sm leading-relaxed","children":"Adjusting lighting quickly between setups"}],["$","li","5",{"className":"text-white/75 text-sm leading-relaxed","children":"Solving problems when conditions change"}]]}],["$","h2","8",{"className":"font-display text-2xl tracking-widest text-white mt-10 mb-4","children":"Why Lighting Matters So Much"}],["$","p","9",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["Most people don't consciously notice good lighting — they just notice that something looks professional, cinematic, or real. Bad lighting, on the other hand, is immediately obvious. Faces look flat, colors look wrong, and the whole production looks cheap regardless of how good the camera is."]}],["$","p","10",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["A skilled gaffer can make a modest budget look expensive. They can make a bland conference room look like a professional studio. They can make outdoor footage shot at the worst possible time of day look intentional and polished."]}],["$","h2","11",{"className":"font-display text-2xl tracking-widest text-white mt-10 mb-4","children":"When Do You Need a Gaffer?"}],["$","p","12",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["For simple run-and-gun video work or documentary-style projects, you may not need a dedicated gaffer. But for anything that requires a controlled, deliberate look — interviews, commercials, narrative work, corporate videos intended for broadcast or high-visibility use — a gaffer is a worthwhile investment."]}],["$","p","13",{"className":"text-white/75 text-sm leading-relaxed mb-4","children":["On the Gulf Coast, gaffers often work across a range of projects from local commercials and music videos to larger productions that come through the region. If your project needs to look its best, finding an experienced gaffer is one of the smartest calls you can make."]}]],["$","div",null,{"className":"mt-12 bg-gradient-to-br from-teal/10 to-transparent border border-teal/20 rounded-2xl p-8 text-center","children":[["$","h3",null,{"className":"font-display text-2xl tracking-widest mb-3","children":"Find a Professional on the Gulf Coast"}],["$","p",null,{"className":"text-muted text-sm mb-6","children":"Browse verified media professionals available for your next project — from Tallahassee to New Orleans."}],["$","div",null,{"className":"flex gap-4 justify-center flex-wrap","children":[["$","$L2",null,{"href":"/browse","className":"btn-teal font-display tracking-widest px-6 py-2","children":"Browse Pros"}],["$","$L2",null,{"href":"/post-job","className":"btn-outline font-display tracking-widest px-6 py-2","children":"Post a Job"}]]}]]}]]}],["$","div",null,{"className":"bg-navy2 border-t border-white/[0.06] py-12 px-4","children":["$","div",null,{"className":"max-w-6xl mx-auto","children":[["$","h2",null,{"className":"font-display text-2xl tracking-widest mb-8 text-center","children":"More Guides"}],["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-3 gap-5","children":[["$","$L2","how-to-prepare-for-a-professional-video-shoot",{"href":"/blog/how-to-prepare-for-a-professional-video-shoot","className":"card p-5 hover:border-teal/40 transition-al